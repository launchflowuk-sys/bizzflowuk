# =============================================================================
# Stage 1: Builder
# Full monorepo install + esbuild bundle
# =============================================================================
FROM node:24-slim AS builder
WORKDIR /app

# cache-bust: 2026-06-15-v4
# Install pnpm via corepack
RUN corepack enable && corepack prepare pnpm@10.26.1 --activate

# Copy workspace manifests first — maximises layer cache reuse
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./

# Copy all source packages that the API server depends on
COPY lib/ lib/
COPY artifacts/api-server/ artifacts/api-server/
COPY scripts/ scripts/

# Install all workspace dependencies
RUN pnpm install --frozen-lockfile

# Generate SQL migration files from schema (no DB connection needed for generate)
# These are copied to the runtime stage and run by scripts/run-migrations.mjs at startup
RUN pnpm --filter @workspace/db run generate

# Bundle the API server with esbuild
RUN pnpm --filter @workspace/api-server run build

# =============================================================================
# Stage 2: Runtime
# Slim image — only what the server and migrations need at runtime
# =============================================================================
FROM node:24-slim AS runtime
WORKDIR /app

# ---- Runtime dependencies ----
# Copy node_modules from builder for the API server bundle (drizzle-orm, pg, express, etc.)
COPY --from=builder /app/node_modules ./node_modules

# Copy lib/db migrations (pre-generated SQL files run by scripts/run-migrations.mjs)
COPY --from=builder /app/lib/db/migrations ./lib/db/migrations

# Workspace root manifests
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/pnpm-workspace.yaml ./pnpm-workspace.yaml

# ---- API server bundle ----
COPY --from=builder /app/artifacts/api-server/dist ./dist

# ---- Startup + migration scripts ----
COPY artifacts/api-server/docker-entrypoint.sh ./docker-entrypoint.sh
COPY scripts/run-migrations.mjs ./scripts/run-migrations.mjs
RUN chmod +x ./docker-entrypoint.sh

ENV NODE_ENV=production
ENV PORT=8080

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
  CMD node -e "require('http').get('http://localhost:8080/api/healthz',(r)=>r.statusCode===200?process.exit(0):process.exit(1)).on('error',()=>process.exit(1))"

ENTRYPOINT ["./docker-entrypoint.sh"]
