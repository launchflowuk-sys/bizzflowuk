# Version control
.git
.gitignore

# Dependencies (rebuilt in Docker)
node_modules
**/node_modules

# Build outputs (rebuilt in Docker)
dist
**/dist
.tsbuildinfo
**/*.tsbuildinfo

# Replit-specific
.replit
.replitignore
.cache
.local

# Environment files (never bake secrets into images)
.env
.env.*
!.env.example

# Development / editor
.vscode
.idea
*.log

# Attached assets (large, not needed for production build)
attached_assets

# pnpm store
.pnpm-store
