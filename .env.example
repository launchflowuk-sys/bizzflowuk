# =============================================================================
# LaunchFlow — Environment Variables
# Copy this file to .env and fill in real values before running locally.
# NEVER commit .env to git. Secrets are set in Coolify's UI for production.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# For docker-compose, this is auto-constructed from POSTGRES_PASSWORD.
# For Coolify managed PostgreSQL, Coolify provides this automatically.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://launchflow:changeme@db:5432/launchflow

# Password for the postgres container (docker-compose only)
POSTGRES_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Clerk Authentication
# Get these from the Replit Auth pane (not dashboard.clerk.com).
# Development keys (pk_test_*) are used automatically by Replit in dev.
# Production keys (pk_live_*) are set via the Auth pane before publishing.
# -----------------------------------------------------------------------------

# Publishable key — safe to expose in frontend bundle (VITE_ prefix required)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret key — NEVER expose this in frontend code or commit to git
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk proxy URL — points to your domain's /clerk-proxy path.
# Enables Clerk to work on custom domains without CNAME DNS setup.
# Example: https://yourdomain.com/clerk-proxy
# Leave blank for local development.
VITE_CLERK_PROXY_URL=

# -----------------------------------------------------------------------------
# Session
# A long random string used to sign session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
SESSION_SECRET=change-this-to-a-long-random-string-at-least-64-chars

# -----------------------------------------------------------------------------
# Object Storage (optional — only needed if using the file/image upload features)
# Configured automatically by Replit Object Storage integration.
# -----------------------------------------------------------------------------
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# -----------------------------------------------------------------------------
# Runtime (set automatically by docker-compose / Coolify — do not set manually)
# -----------------------------------------------------------------------------
# PORT=8080          # API server port (Coolify sets this)
# NODE_ENV=production
