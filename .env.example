# =============================================================================
# BizFlow — Environment Variables
# Production values are set in Coolify's UI — never commit a .env file.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# On Coolify: use the Internal Connection URL from your managed Postgres.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://postgres:changeme@localhost:5432/bizzflow

# -----------------------------------------------------------------------------
# Session / JWT signing
# A long random string used to sign JWT tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
SESSION_SECRET=change-this-to-a-long-random-string-at-least-64-chars

# -----------------------------------------------------------------------------
# File uploads
# Local-disk storage for uploaded files (e.g. visualiser photos). In Docker
# this is a mounted volume (see docker-compose.yml); locally it can be any
# writable directory.
# -----------------------------------------------------------------------------
PRIVATE_UPLOAD_DIR=./data/uploads

# -----------------------------------------------------------------------------
# Platform admin bootstrap (optional)
# Only used the FIRST time each platform admin account is created — existing
# accounts are never modified, so this is safe to leave unset after go-live.
# -----------------------------------------------------------------------------
SEED_ADMIN_PASSWORD=
